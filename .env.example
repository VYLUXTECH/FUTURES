# ============================================================
# FUTURES – Environment Variables
# ============================================================

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- CORS (comma-separated allowed origins) ---
ALLOWED_ORIGINS=http://localhost:8000,https://bot.futuretraders.net

# --- Supabase (Auth + Database) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_DB_URI=postgresql://postgres.yourproject:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require

# --- Supabase JWT Secret (used by middleware to verify tokens) ---
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# --- Encryption (generated via `python -c "from cryptography.fernet import Fernet; import base64; print(base64.urlsafe_b64encode(Fernet.generate_key()).decode())"`) ---
ENCRYPTION_KEY=your-generated-encryption-key

# --- AI Copilot (Custom endpoint) ---
AI_BASE_URL=https://all-in-1-ais.officialhectormanuel.workers.dev
AI_MODEL=deepseek

# --- Hugging Face (vision / chart analysis) ---
HF_TOKEN=hf_your-read-token
HF_VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct

# --- Logging ---
LOG_LEVEL=INFO

# --- Supabase Service Role (admin bot — bypasses RLS) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Frontend Config (injected via /api/config endpoint) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# --- Telegram Admin Bot ---
TELEGRAM_ADMIN_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_ADMIN_ID_1=123456789
TELEGRAM_ADMIN_ID_2=987654321
# --- Telegram Alerts (optional, legacy) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
