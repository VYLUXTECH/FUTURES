# ============================================================
# FUTURES – Environment Variables
# ============================================================

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Supabase (Auth + Database) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_DB_URI=postgresql://postgres.yourproject:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require

# --- OpenRouter / AI Copilot ---
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Logging ---
LOG_LEVEL=INFO

# --- Supabase Service Role (admin bot — bypasses RLS) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Telegram Admin Bot ---
TELEGRAM_ADMIN_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_ADMIN_ID_1=123456789
TELEGRAM_ADMIN_ID_2=987654321
# --- Telegram Alerts (optional, legacy) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
